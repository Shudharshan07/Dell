# MCP Workflow Proxy — copy this file to `.env` and fill in the keys you use.
# Only the provider(s) you actually run need a value.

# Groq (OpenAI-compatible, fast, generous free tier) — recommended for the demo.
GROQ_API_KEY=

# Anthropic Claude (optional).
ANTHROPIC_API_KEY=

# Local Ollama (optional). Default shown; change only if Ollama runs elsewhere.
OLLAMA_BASE_URL=http://localhost:11434
